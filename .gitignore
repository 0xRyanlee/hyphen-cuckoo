# ==================== Cuckoo .gitignore ====================

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Frontend Build ---
dist/
.vite/

# --- Rust ---
src-tauri/target/
src-tauri/gen/
src-tauri/*.db
src-tauri/*.sqlite
src-tauri/*.sqlite3

# --- Debug Output ---
*.bin
debug_*
mock_print.*

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Test Coverage ---
coverage/
*.lcov

# --- Tauri Logs ---
*.log

# --- Environment ---
.env
.env.local
.env.*.local

# --- Logo Options (design files, not production) ---
src-tauri/icons/logo-option-*.svg

# --- Assets (screenshots are optional) ---
# assets/screenshots/

# --- Temporary ---
*.tmp
*.temp
.cache/

# --- Python (build scripts) ---
__pycache__/
*.pyc

# --- Internal / AI-generated dev docs (not for public repo) ---
TODOs.md
docs/archived/
docs/DOCS_INDEX.md
docs/progress/
docs/comprehensive-audit-report-*.md
docs/implementation-audit-report-*.md
docs/info-flow-audit-*.md
docs/recipe-management-audit-*.md
docs/recipe-multi-role-roadmap-*.md
docs/recipe-ux-design-options.md
docs/system-audit-report-*.md
docs/ui-ux-audit-report*.md
docs/workflow-audit-report-*.md
docs/backlog-and-fix-list.md
docs/test-plan-*.md
docs/test-report-*.md

# --- Certs / Signing keys (never commit) ---
certs/
*.jks
*.keystore
keystore.properties
key.properties
